# Ignore bin and obj folders for all projects
**/bin/
**/obj/

# Ignore user-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore Visual Studio folders
.vs/
.vscode/

# Ignore NuGet packages
*.nupkg
packages/

# Ignore EF Core Migrations snapshot files if you want to exclude them
**/Migrations/*.cs
**/Migrations/*.Designer.cs

# Ignore sensitive config files
appsettings.*.json
secrets.json

# Ignore logs
*.log
logs/

# Ignore database files (if any local db)
*.mdf
*.ldf
*.sqlite
.fake
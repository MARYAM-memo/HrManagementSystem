@{
    ViewBag.Title = "Error";
    var code = ViewBag.ErrorCode ?? "Unknown";
}

<div class="container text-center mt-5">
    <h1 class="display-3 text-danger">@code</h1>
    <h2>Error</h2>
    <p class="lead">An error occurred. Please try again or contact support.</p>
    <a class="btn btn-primary mt-3" href="@Url.Action("Index", "Home")">Go Back Home</a>
</div>
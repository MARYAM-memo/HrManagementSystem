@{
    ViewBag.Title = "About HR System";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h1>About Our HR System</h1>
        <p class="lead">A comprehensive Human Resource Management System designed to streamline HR operations.</p>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <h3>System Overview</h3>
            <p>
                This HR System helps organizations manage employee information, payroll, attendance, leave requests,
                job titles, and departments efficiently. It centralizes all HR processes in one platform, reducing
                administrative workload and improving decision-making.
            </p>
        </div>
        <div class="col-md-6">
            <h3>Key Features</h3>
            <ul>
                <li><i class="fas fa-user"></i> Employee Management: Manage employee profiles and employment history.
                </li>
                <li><i class="fas fa-money-bill-wave"></i> Payroll Management: Automated salary calculations and
                    adjustments.</li>
                    <li><i class="fas fa-calendar-check"></i> Attendance Tracking: Track check-in/out and leave requests.
                    </li>
                    <li><i class="fas fa-lock"></i> Role-Based Access: Secure access with roles and permissions.</li>
                    <li><i class="fas fa-chart-bar"></i> Reports & Analytics: Generate detailed HR reports.</li>
                </ul>
            </div>
        </div>

        <div class="mb-4">
            <h3>Benefits</h3>
            <ul>
                <li>Centralized HR operations in one platform</li>
                <li>Improved accuracy and efficiency in HR processes</li>
                <li>Better employee management and engagement</li>
                <li>Secure role-based access control</li>
            </ul>
        </div>

        <div class="mt-5 p-4 bg-light rounded shadow text-center">
            <h3>About the Developer</h3>
            <p>
                This system is a personal training project by <strong>Mariam Mohamed</strong>, aimed to practice
                <strong>ASP.NET MVC, Entity Framework, and Identity</strong>. It demonstrates CRUD operations,
                role-based access control, and Fluent API configuration. The project is part of Mariam's portfolio to
                showcase
                her development skills and learning progress.
            </p>

            <div class="mt-3">
                <a href="https://github.com/MARYAM-memo" target="_blank" class="btn btn-dark me-2">
                    <i class="fab fa-github"></i> GitHub
                </a>
                <a href="https://www.linkedin.com/in/marim-m-03055a196" target="_blank" class="btn btn-primary">
                    <i class="fab fa-linkedin"></i> LinkedIn
                </a>
            </div>
        </div>
    </div>
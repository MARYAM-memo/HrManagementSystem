@{
    ViewBag.Title = "Help - HR System";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4">Help & Support</h1>
        <p class="lead">Find guidance on how to use different features of the HR System efficiently.</p>
    </div>

    <div class="row g-4">
        <!-- Employee Management -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-primary">
                <div class="card-body">
                    <h5 class="card-title text-primary"><i class="fas fa-user"></i> Employee Management</h5>
                    <p class="card-text">
                        Learn how to add, edit, or remove employees, update their personal information,
                        assign them to departments and job titles.
                    </p>
                </div>
            </div>
        </div>

        <!-- Payroll Management -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-success">
                <div class="card-body">
                    <h5 class="card-title text-success"><i class="fas fa-money-bill-wave"></i> Payroll</h5>
                    <p class="card-text">
                        Understand how to manage payroll, calculate salaries, handle adjustments,
                        and generate payroll reports for employees.
                    </p>
                </div>
            </div>
        </div>

        <!-- Attendance Tracking -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-warning">
                <div class="card-body">
                    <h5 class="card-title text-warning"><i class="fas fa-calendar-check"></i> Attendance</h5>
                    <p class="card-text">
                        Track employee check-in/out times, monitor attendance, and handle leave requests efficiently.
                    </p>
                </div>
            </div>
        </div>

        <!-- Leave Management -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-info">
                <div class="card-body">
                    <h5 class="card-title text-info"><i class="fas fa-plane-departure"></i> Leave Requests</h5>
                    <p class="card-text">
                        Submit leave requests, approve or reject requests, and view leave history for employees.
                    </p>
                </div>
            </div>
        </div>

        <!-- Roles & Permissions -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-secondary">
                <div class="card-body">
                    <h5 class="card-title text-secondary"><i class="fas fa-lock"></i> Roles & Permissions</h5>
                    <p class="card-text">
                        Manage user roles, assign permissions, and ensure secure access control for all HR
                        functionalities.
                    </p>
                </div>
            </div>
        </div>

        <!-- Reports & Analytics -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-danger">
                <div class="card-body">
                    <h5 class="card-title text-danger"><i class="fas fa-chart-bar"></i> Reports & Analytics</h5>
                    <p class="card-text">
                        Generate detailed reports on payroll, attendance, and leaves. Analyze data to make informed HR
                        decisions.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 text-center">
        <h3>Need More Help?</h3>
        <p class="lead">You can contact the developer directly for guidance or report any issues.</p>
        <a href="https://github.com/MARYAM-memo" target="_blank" class="btn btn-dark me-2">
            <i class="fab fa-github"></i> GitHub
        </a>
        <a href="https://www.linkedin.com/in/mariam-memo/" target="_blank" class="btn btn-primary">
            <i class="fab fa-linkedin"></i> LinkedIn
        </a>
    </div>
</div>
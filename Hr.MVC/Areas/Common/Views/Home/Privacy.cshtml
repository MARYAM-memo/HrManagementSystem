@{
    ViewBag.Title = "Privacy Policy - HR System";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4">Privacy Policy</h1>
        <p class="lead">This policy explains how the HR System collects, uses, and protects your data.</p>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="card-title">1. Data Collection</h4>
                    <p class="card-text">
                        The HR System collects only the necessary data to manage employee records, payroll, attendance,
                        and leave requests. This may include names, contact information, job titles, and employment
                        history.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="card-title">2. Data Usage</h4>
                    <p class="card-text">
                        All collected data is used solely for HR management purposes, such as payroll calculation,
                        attendance tracking, leave approvals, and reporting. No personal data is shared with third
                        parties
                        without consent.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="card-title">3. Data Protection</h4>
                    <p class="card-text">
                        We implement security measures including role-based access control, encrypted password storage,
                        and secure database access to protect all user information.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="card-title">4. Cookies</h4>
                    <p class="card-text">
                        This HR System does not use cookies to track users. Any session management is handled securely
                        within the system.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="card-title">5. Developer Information</h4>
                    <p class="card-text">
                        This system is a personal training project developed by <strong>Mariam Mohamed</strong> for
                        learning
                        purposes. No real user data is collected in this demo system.
                    </p>

                    <div class="mt-3">
                        <a href="https://github.com/MARYAM-memo" target="_blank" class="btn btn-dark me-2">
                            <i class="fab fa-github"></i> GitHub
                        </a>
                        <a href="https://www.linkedin.com/in/mariam-memo/" target="_blank" class="btn btn-primary">
                            <i class="fab fa-linkedin"></i> LinkedIn
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
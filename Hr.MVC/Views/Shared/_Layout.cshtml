<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/app.css" />
    @* <link rel="stylesheet" href="~/css/custom.css" /> *@
    <link rel="stylesheet" href="~/HrManagementSystem.styles.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>

<body>
    <div class="wrapper">
        <!-- sidebar -->
        <partial name="_SidebarPartial" />
        <div class="main">
            <!-- header -->
            <partial name="_HeaderPartial" />

            <!-- main body -->
            <div class="container flex-fill">
                <main role="main" class="content">
                    <div class="container-fluid p-0">
                        @RenderBody()
                    </div>
                </main>
            </div>

            <footer class="footer">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-6 text-start">
                            <p class="mb-0 text-muted">
                                &copy; @DateTime.Now.Year - HR System
                            </p>
                        </div>
                        <div class="col-6 text-end">
                            <ul class="list-inline mb-0">
                                <li class="list-inline-item">
                                    <a class="text-muted text-decoration-none" asp-area="Common" asp-controller="Home"
                                       asp-action="Help" target="_blank"> Help</a>
                                </li>
                                <li class="list-inline-item">
                                    <a class="text-muted text-decoration-none" asp-area="Common" asp-controller="Home"
                                           asp-action="Privacy" target="_blank">
                                        Privacy
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @* <script src="~/js/app.js"></script>*@
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>


